FUNC_CALL_PROG:
	;store the pointer to the beginning of the program lib to a variable
    LOADIA $PROGRAM_LIB_START_ADDRESS
    STOREA $PROGRAM_LIB_CUR_ADDRESS
    ;store the pointer to the beginning of the buffer to a variable
    LOADIA $BUFFER_START
    STOREA $CUR_BUFFER_ADDRESS
    _CALL_PROG_COMP:
	    ;load a symbol from library to A 
        ;and a symbol from user input to B
        ;we need to use temp variable
	    LOADB $PROGRAM_LIB_CUR_ADDRESS
	    LOADAIND 
        STOREA $TMP
	    LOADB $CUR_BUFFER_ADDRESS
	    LOADAIND 
	    LOADB $TMP
	    ;compare
		SUB
		;if A==0 then the symbols match and we need to read next symbol
		;otherwise skip to next program name in a program library
		JZ _CALL_PROG_COMP_NEXT
_CALL_PROG_SKIP_TO_END_OF_PROG_NAME:
    CALL FUNC_SUB_CALL_PROG_INC_LIB_PNTR
    CALL FUNC_SUB_CALL_PROG_CHECK_LF
    ;if A==0 then we reached the end of the program name in a lib
    ;and we need to skip 1 symbol (an address of the program start)
    ;and check if the table has ended
    ;otherwise increase a pointer further
    JZ _CALL_PROG_CHECK_PROG_LIB_END
    LOADIA 0
    JZ _CALL_PROG_SKIP_TO_END_OF_PROG_NAME
_CALL_PROG_CHECK_PROG_LIB_END:
    ;skip an address of the program start
	CALL FUNC_SUB_CALL_PROG_INC_LIB_PNTR
	CALL FUNC_SUB_CALL_PROG_INC_LIB_PNTR
	;now we’re pointing at the name address OR a table end
    CALL FUNC_SUB_CALL_PROG_CHECK_LF
    ;if A==0 then we need reached the table end
    ;we didn’t find any programs
    JZ _CALL_PROG_NOT_FOUND
    ;otherwise we need to check user input once again 
    ;reset buffer pointer
    LOADIA $BUFFER_START
    STOREA $CUR_BUFFER_ADDRESS
    LOADIA 0
    JZ _CALL_PROG_COMP
_CALL_PROG_COMP_NEXT:
    ;check if current symbol is a line feed
    CALL FUNC_SUB_CALL_PROG_CHECK_LF
    ;if A==0, then we found our program. Otherwise increase counters to check the nex symbol
    JZ _CALL_PROG_FOUND
    ;increase an address of a program library pointer
    CALL FUNC_SUB_CALL_PROG_INC_LIB_PNTR
    ;increase an address of a buffer pointer
    CALL FUNC_SUB_CALL_PROG_INC_BUF_PNTR
    LOADIA 0
    JZ _CALL_PROG_COMP
_CALL_PROG_FOUND:
    ;increase an address of a program library pointer
    CALL FUNC_SUB_CALL_PROG_INC_LIB_PNTR
	;next cell of the program lib contains an address of the program in ROM
    ;load an address of the program into A
	LOADB $PROGRAM_LIB_CUR_ADDRESS 
    LOADAIND 
	RET
_CALL_PROG_NOT_FOUND:
    LOADIA 0
    RET
FUNC_SUB_CALL_PROG_INC_LIB_PNTR:
    LOADA $PROGRAM_LIB_CUR_ADDRESS 
    LOADIB 1
    ADD
    STOREA $PROGRAM_LIB_CUR_ADDRESS
    RET
FUNC_SUB_CALL_PROG_INC_BUF_PNTR:
    LOADA $CUR_BUFFER_ADDRESS
    LOADIB 1
    ADD
    STOREA $CUR_BUFFER_ADDRESS
    RET
;a function to check if the symbol, that $PROGRAM_LIB_CUR_ADDRESS points to
;is a LF. 
;return 0 if it is, otherwise it's not
FUNC_SUB_CALL_PROG_CHECK_LF:
    LOADB $PROGRAM_LIB_CUR_ADDRESS
    LOADAIND
    LOADIB LF
    SUB
    RET




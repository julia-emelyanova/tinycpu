Input assembly 
FUNC_SUB_IS_LAST_IN_BUFFER:
    LOADA $BUFFER_CUR_ELEMENT_POINTER
    LOADIB $BUFFER_END
    ;When A<B, Y=1. Otherwise, Y=0.
    ; if Address<BUFFER_END, then Y=1 and continue
    ; if Address==BUFFER_END, then Y=0 and exit
    SLT   
    RET
FUNC_SUB_IS_LINE_FEED:
    LOADB $BUFFER_CUR_ELEMENT_POINTER
    LOADAIND
    LOADIB LF
    SUB
	RET
FUNC_SUB_INC_BUFFER_POINTER:
    LOADA $BUFFER_CUR_ELEMENT_POINTER
    LOADIB 1
    ADD
    STOREA $BUFFER_CUR_ELEMENT_POINTER
    RET
FUNC_READ_USER_INPUT:
    ;initialize memory cell with array start address
    LOADIA $BUFFER_START
    ;initialize memory cell with a next array element address - at the beginning it’s the same as array start
    STOREA $BUFFER_CUR_ELEMENT_POINTER
    ;read user input until “enter” or buffer end
    ;read
    _FUNC_READ_USER_INPUT_READ:   
        LOADA $KBD_STATUS
        JZ _FUNC_READ_USER_INPUT_READ   
        LOADA $KBD_DATA
        LOADB  $BUFFER_CUR_ELEMENT_POINTER
        STOREAIND
        ;check if it was the last symbol in the buffer
        CALL FUNC_SUB_IS_LAST_IN_BUFFER
        JZ _FUNC_READ_USER_INPUT_END
        ; if the last symbol was an ASCII “line feed” we return
        CALL FUNC_SUB_IS_LINE_FEED
        JZ _FUNC_READ_USER_INPUT_END
        ;increase buffer pointer
        CALL FUNC_SUB_INC_BUFFER_POINTER
        LOADIA 0
        JZ _FUNC_READ_USER_INPUT_READ
    _FUNC_READ_USER_INPUT_END:
        RET
FUNC_PRINT:
    ;initialize memory cell with array start address
    LOADIA $BUFFER_START
    ;initialize memory cell with a next array element address - at the beginning it’s the same as array start
    STOREA $BUFFER_CUR_ELEMENT_POINTER
    _FUNC_PRINT_LOOP: 
        LOADB $BUFFER_CUR_ELEMENT_POINTER
        LOADAIND 
        STOREA  $TTY_OUT
        CALL FUNC_SUB_IS_LAST_IN_BUFFER
        JZ _FUNC_PRINT_END
        CALL FUNC_SUB_IS_LINE_FEED
        JZ _FUNC_PRINT_END
        ;increase buffer pointer
        CALL FUNC_SUB_INC_BUFFER_POINTER
        LOADIA 0
        JZ _FUNC_PRINT_LOOP
    _FUNC_PRINT_END:
        RET
;a function to read user input as a number
;overflow is NOT checked
;a result is stores in the register A
FUNC_READ_NUM:
    CALL FUNC_READ_USER_INPUT
    ;initialize memory cell with array start address
    LOADIA $BUFFER_START
    ;initialize memory cell with a next array element address - at the beginning it’s the same as array start
    STOREA $BUFFER_CUR_ELEMENT_POINTER
    LOADIA 0
    STOREA $RESULT
    _FUNC_READ_NUM_PARSE:
        CALL FUNC_SUB_IS_LAST_IN_BUFFER
        JZ _FUNC_READ_NUM_END
        CALL FUNC_SUB_IS_LINE_FEED
        JZ _FUNC_READ_NUM_END
        ;result = result*10 + digit
        ;multiplication
        ;if res = 0 we don't need tp multiply
        LOADA $RESULT
        JZ _DIGIT
        ;multiply
        LOADB $RESULT
        ADD
        ADD
        ADD
        ADD
        ADD
        ADD
        ADD
        ADD
        ADD
        STOREA $RESULT
    _DIGIT:
        ;calculate digit
        LOADB $BUFFER_CUR_ELEMENT_POINTER
        LOADAIND
        LOADIB '0'
        SUB
    ;calculate result
    LOADB $RESULT
    ADD
    STOREA $RESULT
    ;increase buffer pointer
    CALL FUNC_SUB_INC_BUFFER_POINTER
    LOADIA 0
    JZ _FUNC_READ_NUM_PARSE
    _FUNC_READ_NUM_END:
        LOADA $RESULT
        RET

